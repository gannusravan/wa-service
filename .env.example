# ── Server ──────────────────────────────────────────────────────────────────
# Port this WhatsApp service listens on. Run one instance per app with a
# different port (e.g. 5013 for app A, 5014 for app B).
PORT=5013

# Folder where each session's WhatsApp credentials are stored. Use a unique
# value per app/instance if multiple instances share a disk.
AUTH_DIR=auth

# ── Backend integration (any stack: Laravel, MERN/Express, Django, ...) ──────
# HTTP endpoint this service POSTs session events to. Leave blank to disable.
# Receives JSON: { event, sessionId, status?, phone?, from?, text?, ... }
WEBHOOK_URL=http://localhost:8000/api/whatsapp/webhook

# Optional shared secret sent as the X-Webhook-Secret header so your backend
# can verify the webhook genuinely came from this service.
WEBHOOK_SECRET=

# Set to "true" to forward inbound WhatsApp messages to WEBHOOK_URL as
# { event: "message", from, text, messageId, timestamp }. Default: off.
FORWARD_INBOUND=false

# ── Security ────────────────────────────────────────────────────────────────
# When set, every REST request must send a matching X-API-Key header (or
# ?apiKey=). Leave blank to keep the API open. GET /health stays public.
API_KEY=

# Restrict browser CORS to your frontend origin (e.g. https://app.example.com).
# Defaults to * (any origin).
CORS_ORIGIN=*
